# ============================================================
# Flash-Engine-V2-LowComp — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your real .env to version control.
# ============================================================

# WebSocket RPC endpoint for Base mainnet.
# Free options: wss://base.llamarpc.com
# Paid (recommended): Alchemy, QuickNode, Chainstack
BASE_RPC_URL=wss://base.llamarpc.com

# Private key of the wallet that will sign transactions.
# This wallet must hold a small amount of ETH on Base for gas.
PRIVATE_KEY=your_private_key_here

# Deployed address of the FlashArbitrageV2 contract.
# Set this after running: npm run deploy
CONTRACT_ADDRESS=0xYourDeployedContractAddressHere

# Balancer V2 Vault on Base mainnet (0% flash loan fee).
# Do not change unless Balancer deploys a new vault.
BALANCER_VAULT_ADDRESS=0xBA12222222228d8Ba445958a75a0704d566BF2C8

# Amount of WETH to borrow per flash loan, in wei.
# Default: 1 WETH = 1000000000000000000
# Increase for larger arbitrage positions (ensure contract has enough WETH for repayment buffer).
FLASH_LOAN_AMOUNT=1000000000000000000

# Minimum net profit in USD required to trigger a flash loan.
# Trades with expected profit below this threshold are skipped.
# Default: $0.50
MIN_PROFIT_USD=0.50
